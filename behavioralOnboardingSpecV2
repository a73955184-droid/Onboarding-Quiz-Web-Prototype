# Shared Utilities

Use this on every screen.

```js
function getState() {
  const params = new URLSearchParams(window.location.search);
  const stateParam = params.get('state');

  if (!stateParam) {
    return {
      scores: {
        BFO: 0,
        GD: 0,
        FT: 0,
        GA: 0,
        TO: 0,
        IP: 0,
        ES: 0
      },
      answers: {},
      metadata: {}
    };
  }

  try {
    return JSON.parse(decodeURIComponent(stateParam));
  } catch (e) {
    console.error('State parse error', e);
    return {
      scores: {
        BFO: 0,
        GD: 0,
        FT: 0,
        GA: 0,
        TO: 0,
        IP: 0,
        ES: 0
      },
      answers: {},
      metadata: {}
    };
  }
}

function goTo(nextPage, state) {
  const encoded = encodeURIComponent(JSON.stringify(state));
  window.location.href = `${nextPage}?state=${encoded}`;
}
```

